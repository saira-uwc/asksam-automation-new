{
  "name": "playwright-automation-v1.1",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
"scripts": {
  "test": "npx playwright test",
  "test:headed": "npx playwright test --headed",
  "publish": "bash scripts/publish-pages.sh",
  "report": "npx playwright show-report reports/html-report",
  "clean:allure": "rm -rf reports/allure-results reports/allure-report",
  "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
  "allure:open": "allure open reports/allure-report",
  "test:file": "node -r dotenv/config ./node_modules/playwright/cli.js test",
  "publish:pages": "bash scripts/publish-pages.sh"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "allure-playwright": "^3.4.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "google-auth-library": "^10.5.0",
    "google-spreadsheet": "^5.0.2",
    "googleapis": "^168.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11"
  }
}
